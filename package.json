    "./themes/light.css": "./dist/themes/light.css",
    "./themes/hulk.css": "./dist/themes/hulk.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "node ./scripts/sync.mjs",
    "build": "node ./scripts/build.mjs",
    "test": "node ./tests/runtime/deckzero.test.mjs && node ./tests/compiler/markdown.test.mjs && node ./tests/compiler/build.test.mjs"
  }
